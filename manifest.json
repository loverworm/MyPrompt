{
  "manifest_version": 3,
  "name": "我的提示词管理器",
  "version": "1.7.2",
  "description": "一键管理、填入提示词，支持网页内快捷唤起",
  "author": "董琪",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.deepseek.com/*",
    "https://*.doubao.com/*",
    "https://*.kimi.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L"
      },
      "description": "唤起提示词管理器"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.doubao.com/*",
        "https://*.kimi.com/*",
        "https://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}